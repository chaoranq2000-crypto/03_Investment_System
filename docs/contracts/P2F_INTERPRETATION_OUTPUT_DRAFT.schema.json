{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/p2f.interpretation_output.v1.schema.json",
  "title": "P2F bounded interpretation provider output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "interpretation_sections"
  ],
  "properties": {
    "schema_version": {
      "const": "p2f.interpretation_output.v1"
    },
    "interpretation_sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_tensions",
        "hypotheses",
        "alternative_explanations",
        "counterfactual_options",
        "history_links"
      ],
      "properties": {
        "main_tensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/findingProposal"
          }
        },
        "hypotheses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/findingProposal"
          }
        },
        "alternative_explanations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/findingProposal"
          }
        },
        "counterfactual_options": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/counterfactualProposal"
          }
        },
        "history_links": {
          "type": "array",
          "maxItems": 0
        }
      }
    }
  },
  "$defs": {
    "factId": {
      "type": "string",
      "pattern": "^fact:[0-9a-f]{32}$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findingProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "perspective",
        "statement",
        "confidence",
        "fact_refs",
        "counterevidence_status",
        "counterevidence_fact_refs",
        "assumptions",
        "uncertainty"
      ],
      "properties": {
        "kind": {
          "enum": [
            "main_tension",
            "hypothesis",
            "alternative_explanation"
          ]
        },
        "perspective": {
          "enum": [
            "decision_time",
            "retrospective"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "fact_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/factId"
          }
        },
        "counterevidence_status": {
          "enum": [
            "available",
            "missing",
            "not_applicable"
          ]
        },
        "counterevidence_fact_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/factId"
          }
        },
        "assumptions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "uncertainty": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "counterfactualProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "fact_refs",
        "temporal_scope",
        "feasibility",
        "tradeoffs",
        "not_advice"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fact_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/factId"
          }
        },
        "temporal_scope": {
          "enum": [
            "decision_time",
            "episode_time"
          ]
        },
        "feasibility": {
          "enum": [
            "known_feasible",
            "possibly_feasible",
            "unknown"
          ]
        },
        "tradeoffs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "not_advice": {
          "const": true
        }
      }
    }
  }
}
