{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/p2f.human_review_request.v1.schema.json",
  "title": "P2F append-only human review request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action",
    "reviewed_at",
    "actor_ref",
    "reason",
    "target_ids",
    "corrections"
  ],
  "properties": {
    "schema_version": {
      "const": "p2f.human_review_request.v1"
    },
    "action": {
      "enum": [
        "accept",
        "reject",
        "correct"
      ]
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor_ref": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "target_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:finding|option):[0-9a-f]{32}$"
      }
    },
    "corrections": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/correction"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "accept",
              "reject"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "target_ids": {
            "items": {
              "type": "string",
              "pattern": "^finding:[0-9a-f]{32}$"
            }
          },
          "corrections": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "correct"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "corrections": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "factIdArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^fact:[0-9a-f]{32}$"
      }
    },
    "correction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "target_id",
        "fact_refs"
      ],
      "properties": {
        "operation": {
          "const": "replace_fact_refs"
        },
        "target_id": {
          "type": "string",
          "pattern": "^(?:finding|option):[0-9a-f]{32}$"
        },
        "fact_refs": {
          "$ref": "#/$defs/factIdArray"
        },
        "counterevidence_status": {
          "enum": [
            "available",
            "missing",
            "not_applicable"
          ]
        },
        "counterevidence_fact_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^fact:[0-9a-f]{32}$"
          }
        }
      }
    }
  }
}
