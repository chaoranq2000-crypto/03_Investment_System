{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/p2g.behavior_hypothesis_review_request.v1.schema.json",
  "title": "P2G-4 atomic behavior hypothesis review request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "expected_parent_content_id",
    "actor",
    "reviewed_at",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "const": "p2g.behavior_hypothesis_review_request.v1"
    },
    "request_id": {
      "type": "string",
      "pattern": "^review-request:[0-9a-f]{32}$"
    },
    "expected_parent_content_id": {
      "$ref": "#/$defs/contentId"
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/reviewAction"
      }
    }
  },
  "$defs": {
    "contentId": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "hypothesisId": {
      "type": "string",
      "pattern": "^hypothesis:[0-9a-f]{32}$"
    },
    "evaluationIdArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^evaluation:[0-9a-f]{32}$"
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 10000
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episode_ids",
        "start_at",
        "end_at",
        "market_contexts"
      ],
      "properties": {
        "episode_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "start_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "end_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "market_contexts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "replacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "scope",
        "evaluation_refs",
        "supporting_reasons",
        "counterevidence_evaluation_refs",
        "counterevidence_search",
        "alternative_explanations",
        "assumptions",
        "uncertainty_notes",
        "falsification_conditions",
        "next_observations_needed",
        "temporal_perspective"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10000
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "evaluation_refs": {
          "allOf": [
            {
              "$ref": "#/$defs/evaluationIdArray"
            },
            {
              "minItems": 1
            }
          ]
        },
        "supporting_reasons": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "counterevidence_evaluation_refs": {
          "$ref": "#/$defs/evaluationIdArray"
        },
        "counterevidence_search": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 10000
        },
        "alternative_explanations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "assumptions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "uncertainty_notes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "falsification_conditions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "next_observations_needed": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "temporal_perspective": {
          "const": "retrospective"
        }
      }
    },
    "reviewAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_hypothesis_id",
        "action",
        "reason",
        "replacement"
      ],
      "properties": {
        "target_hypothesis_id": {
          "$ref": "#/$defs/hypothesisId"
        },
        "action": {
          "enum": [
            "accept",
            "reject",
            "correct"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10000
        },
        "replacement": {
          "oneOf": [
            {
              "$ref": "#/$defs/replacement"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "correct"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "replacement": {
                "$ref": "#/$defs/replacement"
              }
            }
          },
          "else": {
            "properties": {
              "replacement": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  }
}
