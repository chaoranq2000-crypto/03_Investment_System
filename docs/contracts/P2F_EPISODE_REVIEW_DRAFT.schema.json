{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/p2f.episode_review.v1.schema.json",
  "title": "P2F Episode Review Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "content_id",
    "review_id",
    "input_bundle_ref",
    "revision",
    "fact_sections",
    "interpretation_sections",
    "governance",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "p2f.episode_review.v1"
    },
    "content_id": {
      "$ref": "#/$defs/contentId"
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "input_bundle_ref": {
      "$ref": "#/$defs/artifactRef"
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision_no",
        "status",
        "supersedes_content_id",
        "correction_reason"
      ],
      "properties": {
        "revision_no": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "enum": [
            "draft",
            "reviewed",
            "corrected",
            "superseded"
          ]
        },
        "supersedes_content_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/contentId"
            },
            {
              "type": "null"
            }
          ]
        },
        "correction_reason": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "fact_sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeline",
        "security_context",
        "portfolio_context",
        "market_context",
        "outcome_context",
        "execution_consistency"
      ],
      "properties": {
        "timeline": {
          "$ref": "#/$defs/factSection"
        },
        "security_context": {
          "$ref": "#/$defs/factSection"
        },
        "portfolio_context": {
          "$ref": "#/$defs/factSection"
        },
        "market_context": {
          "$ref": "#/$defs/factSection"
        },
        "outcome_context": {
          "$ref": "#/$defs/factSection"
        },
        "execution_consistency": {
          "$ref": "#/$defs/factSection"
        }
      }
    },
    "interpretation_sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_tensions",
        "hypotheses",
        "alternative_explanations",
        "counterfactual_options",
        "history_links"
      ],
      "properties": {
        "main_tensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "hypotheses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "alternative_explanations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "counterfactual_options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/counterfactual"
          }
        },
        "history_links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/historyLink"
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facts_interpretation_separated",
        "no_advice",
        "no_mechanical_score",
        "generation_mode",
        "model_generation",
        "human_reviews"
      ],
      "properties": {
        "facts_interpretation_separated": {
          "const": true
        },
        "no_advice": {
          "const": true
        },
        "no_mechanical_score": {
          "const": true
        },
        "generation_mode": {
          "enum": [
            "facts_only",
            "model_assisted",
            "human_authored"
          ]
        },
        "model_generation": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "model_id",
                "prompt_template_id",
                "prompt_hash",
                "input_content_id",
                "output_hash",
                "parameters",
                "generated_at"
              ],
              "properties": {
                "model_id": {
                  "type": "string",
                  "minLength": 1
                },
                "prompt_template_id": {
                  "type": "string",
                  "minLength": 1
                },
                "prompt_hash": {
                  "$ref": "#/$defs/contentId"
                },
                "input_content_id": {
                  "$ref": "#/$defs/contentId"
                },
                "output_hash": {
                  "$ref": "#/$defs/contentId"
                },
                "parameters": {
                  "$ref": "#/$defs/canonicalObject"
                },
                "generated_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          ]
        },
        "human_reviews": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "review_event_id",
              "action",
              "reviewed_at",
              "actor_ref"
            ],
            "properties": {
              "review_event_id": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "enum": [
                  "accept",
                  "reject",
                  "correct",
                  "supersede"
                ]
              },
              "reviewed_at": {
                "type": "string",
                "format": "date-time"
              },
              "actor_ref": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              },
              "target_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "governance": {
            "properties": {
              "generation_mode": {
                "const": "facts_only"
              }
            },
            "required": [
              "generation_mode"
            ]
          }
        },
        "required": [
          "governance"
        ]
      },
      "then": {
        "properties": {
          "governance": {
            "properties": {
              "model_generation": {
                "type": "null"
              }
            }
          },
          "interpretation_sections": {
            "properties": {
              "main_tensions": {
                "maxItems": 0
              },
              "hypotheses": {
                "maxItems": 0
              },
              "alternative_explanations": {
                "maxItems": 0
              },
              "counterfactual_options": {
                "maxItems": 0
              },
              "history_links": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "governance": {
            "properties": {
              "generation_mode": {
                "const": "model_assisted"
              }
            },
            "required": [
              "generation_mode"
            ]
          }
        },
        "required": [
          "governance"
        ]
      },
      "then": {
        "properties": {
          "governance": {
            "properties": {
              "model_generation": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "governance": {
            "properties": {
              "generation_mode": {
                "const": "human_authored"
              }
            },
            "required": [
              "generation_mode"
            ]
          }
        },
        "required": [
          "governance"
        ]
      },
      "then": {
        "properties": {
          "governance": {
            "properties": {
              "model_generation": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "content_id",
        "episode_id"
      ],
      "properties": {
        "schema_version": {
          "const": "p2f.review_input_bundle.v1"
        },
        "content_id": {
          "$ref": "#/$defs/contentId"
        },
        "episode_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contentId": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "warningCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "canonicalObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/canonicalValue"
      }
    },
    "canonicalValue": {
      "description": "Canonical JSON value. Fractional numerics must be Decimal strings; runtime semantic validation must additionally reject binary float values such as 1.0 that JSON Schema may classify as integer-valued numbers.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonicalValue"
          }
        },
        {
          "$ref": "#/$defs/canonicalObject"
        }
      ]
    },
    "availability": {
      "enum": [
        "available",
        "missing",
        "unlinked",
        "ambiguous",
        "stale",
        "unpriced",
        "invalid",
        "not_applicable",
        "withheld_by_cutoff",
        "partial"
      ]
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_kind",
        "content_id",
        "locator",
        "frozen_pointer"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "minLength": 1
        },
        "content_id": {
          "$ref": "#/$defs/contentId"
        },
        "locator": {
          "type": "string"
        },
        "frozen_pointer": {
          "type": "string",
          "pattern": "^/frozen_sources/"
        }
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact_id",
        "kind",
        "claim_type",
        "statement",
        "availability",
        "temporal_role",
        "effective_at",
        "knowledge_at",
        "source_refs",
        "warning_codes",
        "data"
      ],
      "properties": {
        "fact_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "episode_lifecycle",
            "execution_event",
            "security_identity",
            "recorded_decision",
            "recorded_note",
            "portfolio_anchor",
            "portfolio_metric",
            "portfolio_delta",
            "market_record",
            "outcome_record",
            "decision_execution_link",
            "plan_execution_comparison"
          ]
        },
        "claim_type": {
          "enum": [
            "fact",
            "estimate",
            "management_comment",
            "analyst_view",
            "opinion",
            "unknown"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "$ref": "#/$defs/availability"
        },
        "temporal_role": {
          "enum": [
            "known_at_decision",
            "learned_during_episode",
            "known_after_episode",
            "not_applicable"
          ]
        },
        "effective_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "knowledge_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "warning_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/warningCode"
          }
        },
        "data": {
          "$ref": "#/$defs/canonicalObject"
        }
      }
    },
    "factSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "source_ids",
        "warning_codes",
        "gap_codes",
        "facts"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/availability"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "warning_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/warningCode"
          }
        },
        "facts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fact"
          }
        },
        "gap_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/warningCode"
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "kind",
        "statement",
        "confidence",
        "fact_refs",
        "assumptions",
        "uncertainty",
        "review_status"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "main_tension",
            "hypothesis",
            "alternative_explanation"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "fact_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "counterevidence_fact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainty": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "enum": [
            "draft",
            "accepted",
            "rejected",
            "revised"
          ]
        }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "option_id",
        "description",
        "fact_refs",
        "feasibility",
        "tradeoffs",
        "not_advice"
      ],
      "properties": {
        "option_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fact_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "feasibility": {
          "enum": [
            "known_feasible",
            "possibly_feasible",
            "unknown"
          ]
        },
        "tradeoffs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "not_advice": {
          "const": true
        }
      }
    },
    "historyLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_id",
        "status",
        "basis_fact_refs"
      ],
      "properties": {
        "link_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "available",
            "missing",
            "ambiguous",
            "not_applicable"
          ]
        },
        "comparison_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "basis_fact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "target_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
