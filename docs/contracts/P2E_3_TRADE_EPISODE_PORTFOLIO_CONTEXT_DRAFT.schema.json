{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/p2e3.trade_episode_portfolio_context.v1.schema.json",
  "title": "P2E-3 Trade Episode Portfolio Context (Draft)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "content_id",
    "episode_artifact_ref",
    "as_of",
    "knowledge_cutoff",
    "contexts",
    "deltas",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "p2e3.trade_episode_portfolio_context.v1"
    },
    "content_id": {
      "$ref": "#/$defs/content_id"
    },
    "episode_artifact_ref": {
      "$ref": "#/$defs/artifact_ref"
    },
    "as_of": {
      "$ref": "#/$defs/timestamp"
    },
    "knowledge_cutoff": {
      "$ref": "#/$defs/timestamp"
    },
    "metric_registry_version": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context"
      }
    },
    "deltas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delta"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "content_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stable_id": {
      "type": "string",
      "minLength": 1
    },
    "decimal": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_id",
        "schema_version"
      ],
      "properties": {
        "content_id": {
          "$ref": "#/$defs/content_id"
        },
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "$ref": "#/$defs/stable_id"
        },
        "effective_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "knowledge_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "revision": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message",
        "source_refs"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "side",
        "event_id",
        "event_at",
        "as_of",
        "knowledge_cutoff",
        "ordering_key"
      ],
      "properties": {
        "kind": {
          "enum": [
            "episode_open",
            "position_change",
            "episode_close"
          ]
        },
        "side": {
          "enum": [
            "pre",
            "post"
          ]
        },
        "event_id": {
          "$ref": "#/$defs/stable_id"
        },
        "event_at": {
          "$ref": "#/$defs/timestamp"
        },
        "as_of": {
          "$ref": "#/$defs/timestamp"
        },
        "knowledge_cutoff": {
          "$ref": "#/$defs/timestamp"
        },
        "ordering_key": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": [
              "string",
              "integer"
            ]
          }
        }
      }
    },
    "snapshot_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "snapshot_id",
        "revision",
        "source_refs"
      ],
      "properties": {
        "status": {
          "enum": [
            "exact",
            "replayed",
            "missing",
            "ambiguous",
            "invalid"
          ]
        },
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "revision": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      }
    },
    "method_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "method_version"
      ],
      "properties": {
        "method_id": {
          "type": "string",
          "minLength": 1
        },
        "method_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "value",
        "unit",
        "method",
        "source_refs",
        "warning_codes"
      ],
      "properties": {
        "availability": {
          "enum": [
            "available",
            "partial",
            "missing",
            "not_applicable",
            "invalid"
          ]
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "anyOf": [
            {
              "$ref": "#/$defs/method_ref"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "warning_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "episode_id",
        "decision_link_status",
        "target_symbol",
        "anchor",
        "portfolio_snapshot",
        "metrics",
        "warnings"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "episode_id": {
          "$ref": "#/$defs/stable_id"
        },
        "decision_link_status": {
          "enum": [
            "linked",
            "unlinked",
            "ambiguous",
            "invalid",
            "missing"
          ]
        },
        "target_symbol": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "$ref": "#/$defs/anchor"
        },
        "portfolio_snapshot": {
          "$ref": "#/$defs/snapshot_ref"
        },
        "metrics": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/metric"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_id",
        "episode_id",
        "metric_key",
        "from_context_id",
        "to_context_id",
        "availability",
        "value",
        "unit",
        "method_compatibility",
        "warning_codes"
      ],
      "properties": {
        "delta_id": {
          "$ref": "#/$defs/stable_id"
        },
        "episode_id": {
          "$ref": "#/$defs/stable_id"
        },
        "metric_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "from_context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "to_context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "availability": {
          "enum": [
            "available",
            "missing",
            "not_comparable",
            "invalid"
          ]
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "method_compatibility": {
          "enum": [
            "same",
            "compatible",
            "incompatible",
            "unknown"
          ]
        },
        "warning_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          }
        }
      }
    }
  }
}
