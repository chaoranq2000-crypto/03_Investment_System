{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/p2e3.trade_episode_portfolio_context.v1.schema.json",
  "title": "P2E-3 Trade Episode Portfolio Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "content_id",
    "episode_artifact_ref",
    "source_binding",
    "as_of",
    "knowledge_cutoff",
    "metric_registry_version",
    "contexts",
    "deltas",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "p2e3.trade_episode_portfolio_context.v1"
    },
    "content_id": {
      "$ref": "#/$defs/content_id"
    },
    "episode_artifact_ref": {
      "$ref": "#/$defs/artifact_ref"
    },
    "source_binding": {
      "$ref": "#/$defs/source_binding"
    },
    "as_of": {
      "$ref": "#/$defs/timestamp"
    },
    "knowledge_cutoff": {
      "$ref": "#/$defs/timestamp"
    },
    "metric_registry_version": {
      "const": "p2e2.portfolio_metric_registry.v1"
    },
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context"
      }
    },
    "deltas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delta"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "content_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stable_id": {
      "type": "string",
      "minLength": 1
    },
    "decimal": {
      "type": "string",
      "pattern": "^(?:0|-?(?:[1-9][0-9]*(?:\\.[0-9]*[1-9])?|0\\.[0-9]*[1-9]))$"
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_id",
        "schema_version"
      ],
      "properties": {
        "content_id": {
          "$ref": "#/$defs/content_id"
        },
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "requested_episode_ids", "resolved_episode_ids"],
      "properties": {
        "mode": {"enum": ["all_visible", "explicit"]},
        "requested_episode_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stable_id"}
        },
        "resolved_episode_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stable_id"}
        }
      }
    },
    "ordering_key": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {"$ref": "#/$defs/timestamp"},
        {"type": "integer"},
        {"type": "string"},
        {"type": "string", "minLength": 1}
      ],
      "items": false
    },
    "material_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episode_id", "episode_content_id", "event_id", "event_content_id",
        "anchor_kind", "event_at", "known_at", "ordering_key",
        "target_symbol", "decision_link_status"
      ],
      "properties": {
        "episode_id": {"$ref": "#/$defs/stable_id"},
        "episode_content_id": {"$ref": "#/$defs/content_id"},
        "event_id": {"$ref": "#/$defs/stable_id"},
        "event_content_id": {"$ref": "#/$defs/content_id"},
        "anchor_kind": {
          "enum": ["episode_open", "position_change", "episode_close"]
        },
        "event_at": {"$ref": "#/$defs/timestamp"},
        "known_at": {"$ref": "#/$defs/timestamp"},
        "ordering_key": {"$ref": "#/$defs/ordering_key"},
        "target_symbol": {"type": "string", "minLength": 1},
        "decision_link_status": {
          "enum": ["linked", "unlinked", "ambiguous", "invalid", "missing"]
        }
      }
    },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "episode_collection_content_id",
        "episode_collection_cutoff", "selection", "material_events",
        "material_event_set_content_id"
      ],
      "properties": {
        "schema_version": {"const": "p2e3.source_binding.v1"},
        "episode_collection_content_id": {"$ref": "#/$defs/content_id"},
        "episode_collection_cutoff": {"$ref": "#/$defs/timestamp"},
        "selection": {"$ref": "#/$defs/selection"},
        "material_events": {
          "type": "array",
          "items": {"$ref": "#/$defs/material_event"}
        },
        "material_event_set_content_id": {"$ref": "#/$defs/content_id"}
      }
    },
    "cursor_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cursor_scope", "included_event_set_complete", "boundary_limited"
      ],
      "properties": {
        "cursor_scope": {"enum": ["account", "partition", "unknown"]},
        "included_event_set_complete": {"type": "boolean"},
        "boundary_limited": {"type": "boolean"}
      }
    },
    "snapshot_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id", "revision", "state_content_id", "catalog_content_id",
        "included_event_ids_content_id", "same_business_day", "cursor_scope",
        "included_event_set_complete", "metric_availability_ceiling"
      ],
      "properties": {
        "snapshot_id": {"type": "string", "minLength": 1},
        "revision": {"type": ["string", "integer"]},
        "state_content_id": {"$ref": "#/$defs/content_id"},
        "catalog_content_id": {"$ref": "#/$defs/content_id"},
        "included_event_ids_content_id": {"$ref": "#/$defs/content_id"},
        "same_business_day": {"type": "boolean"},
        "cursor_scope": {"enum": ["account", "partition"]},
        "included_event_set_complete": {"type": "boolean"},
        "metric_availability_ceiling": {
          "enum": ["available", "partial", "none"]
        }
      }
    },
    "context_source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["episode_content_id", "event_content_id", "snapshot_binding"],
      "properties": {
        "episode_content_id": {"$ref": "#/$defs/content_id"},
        "event_content_id": {"$ref": "#/$defs/content_id"},
        "snapshot_binding": {
          "anyOf": [
            {"$ref": "#/$defs/snapshot_binding"},
            {"type": "null"}
          ]
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id",
        "effective_at",
        "knowledge_at",
        "revision"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "$ref": "#/$defs/stable_id"
        },
        "effective_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "knowledge_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "revision": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "content_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/content_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message",
        "source_refs"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "side",
        "event_id",
        "event_at",
        "as_of",
        "knowledge_cutoff",
        "ordering_key"
      ],
      "properties": {
        "kind": {
          "enum": [
            "episode_open",
            "position_change",
            "episode_close"
          ]
        },
        "side": {
          "enum": [
            "pre",
            "post"
          ]
        },
        "event_id": {
          "$ref": "#/$defs/stable_id"
        },
        "event_at": {
          "$ref": "#/$defs/timestamp"
        },
        "as_of": {
          "$ref": "#/$defs/timestamp"
        },
        "knowledge_cutoff": {
          "$ref": "#/$defs/timestamp"
        },
        "ordering_key": {
          "$ref": "#/$defs/ordering_key"
        }
      }
    },
    "snapshot_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "snapshot_id",
        "revision",
        "base_currency",
        "cursor_proof",
        "source_refs"
      ],
      "properties": {
        "status": {
          "enum": [
            "exact",
            "replayed",
            "missing",
            "ambiguous",
            "invalid"
          ]
        },
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "revision": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "base_currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3}$"
        },
        "cursor_proof": {
          "$ref": "#/$defs/cursor_proof"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "exact",
                  "replayed",
                  "invalid"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "snapshot_id": {
                "type": "string",
                "minLength": 1
              },
              "revision": {
                "type": [
                  "string",
                  "integer"
                ]
              },
              "base_currency": {
                "type": "string",
                "pattern": "^[A-Z]{3}$"
              },
              "source_refs": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "missing",
                  "ambiguous"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "snapshot_id": {
                "type": "null"
              },
              "revision": {
                "type": "null"
              },
              "base_currency": {
                "type": "null"
              },
              "source_refs": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "method_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "method_version"
      ],
      "properties": {
        "method_id": {
          "type": "string",
          "minLength": 1
        },
        "method_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "value",
        "unit",
        "method",
        "source_refs",
        "warning_codes"
      ],
      "properties": {
        "availability": {
          "enum": [
            "available",
            "partial",
            "missing",
            "not_applicable",
            "invalid"
          ]
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "anyOf": [
            {
              "$ref": "#/$defs/method_ref"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "warning_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "enum": [
                  "available",
                  "partial"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "$ref": "#/$defs/decimal"
              },
              "method": {
                "$ref": "#/$defs/method_ref"
              },
              "source_refs": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "value": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "episode_id",
        "decision_link_status",
        "target_symbol",
        "source_binding",
        "anchor",
        "portfolio_snapshot",
        "metrics",
        "warnings"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "episode_id": {
          "$ref": "#/$defs/stable_id"
        },
        "decision_link_status": {
          "enum": [
            "linked",
            "unlinked",
            "ambiguous",
            "invalid",
            "missing"
          ]
        },
        "target_symbol": {
          "type": "string",
          "minLength": 1
        },
        "source_binding": {
          "$ref": "#/$defs/context_source_binding"
        },
        "anchor": {
          "$ref": "#/$defs/anchor"
        },
        "portfolio_snapshot": {
          "$ref": "#/$defs/snapshot_ref"
        },
        "metrics": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/metric"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_id",
        "episode_id",
        "metric_key",
        "from_context_id",
        "to_context_id",
        "availability",
        "value",
        "unit",
        "method_compatibility",
        "warning_codes"
      ],
      "properties": {
        "delta_id": {
          "$ref": "#/$defs/stable_id"
        },
        "episode_id": {
          "$ref": "#/$defs/stable_id"
        },
        "metric_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "from_context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "to_context_id": {
          "$ref": "#/$defs/stable_id"
        },
        "availability": {
          "enum": [
            "available",
            "missing",
            "not_comparable",
            "invalid"
          ]
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "method_compatibility": {
          "enum": [
            "same",
            "incompatible",
            "unknown"
          ]
        },
        "warning_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "availability": {
                "const": "available"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "$ref": "#/$defs/decimal"
              },
              "method_compatibility": {
                "const": "same"
              }
            }
          },
          "else": {
            "properties": {
              "value": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  }
}
