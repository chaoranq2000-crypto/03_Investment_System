{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "r5_night_shift_task_queue_v1",
  "title": "R5 Night Shift Task Queue",
  "type": "object",
  "required": [
    "schema_version",
    "mission_id",
    "baseline",
    "run_window",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "r5_night_shift_queue_v1"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": "object"
    },
    "run_window": {
      "type": "object"
    },
    "task_selection": {
      "type": "object"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "priority",
        "status",
        "depends_on",
        "work_type",
        "goal",
        "allowed_paths",
        "forbidden_paths",
        "acceptance_commands",
        "required_artifacts",
        "retry_limit",
        "on_success",
        "on_failure",
        "human_gate",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ns[0-9]{2}_t[0-9]{2}_[a-z0-9_]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "enum": [
            "pending",
            "ready",
            "claimed",
            "running",
            "passed",
            "failed_retryable",
            "failed_terminal",
            "dependency_blocked",
            "evidence_required",
            "human_gate",
            "skipped_cutoff"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "work_type": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retry_limit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "on_success": {
          "type": "object"
        },
        "on_failure": {
          "type": "object"
        },
        "human_gate": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
