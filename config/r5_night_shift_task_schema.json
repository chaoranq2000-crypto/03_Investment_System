{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "r5_night_shift_task_queue_v1",
  "title": "R5 Night Shift Task Queue",
  "type": "object",
  "required": [
    "schema_version",
    "mission_id",
    "baseline",
    "run_window",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "r5_night_shift_queue_v1",
        "r5_night_shift_queue_v2_proposed",
        "r5_night_shift_queue_v2"
      ]
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": "object"
    },
    "run_window": {
      "type": "object"
    },
    "task_selection": {
      "type": "object"
    },
    "long_term_goal": {
      "type": "object"
    },
    "mission_policy": {
      "type": "object"
    },
    "read_only_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "r5_night_shift_queue_v2"
          }
        }
      },
      "then": {
        "properties": {
          "tasks": {
            "items": {
              "required": [
                "phase",
                "estimated_work_units",
                "delivery_required",
                "contract_origin",
                "path_authority",
                "acceptance_authority",
                "review_state",
                "review_sha",
                "resolution_claims"
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "priority",
        "status",
        "depends_on",
        "work_type",
        "goal",
        "allowed_paths",
        "forbidden_paths",
        "acceptance_commands",
        "required_artifacts",
        "retry_limit",
        "on_success",
        "on_failure",
        "human_gate",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ns[0-9]{2}_t[0-9]{2}_[a-z0-9_]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "status": {
          "enum": [
            "pending",
            "ready",
            "claimed",
            "running",
            "passed",
            "failed_retryable",
            "failed_terminal",
            "dependency_blocked",
            "evidence_required",
            "human_gate",
            "skipped_cutoff",
            "blocked_external"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "work_type": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retry_limit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "on_success": {
          "type": "object"
        },
        "on_failure": {
          "type": "object"
        },
        "human_gate": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "type": "string"
        },
        "estimated_work_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "delivery_required": {
          "type": "boolean"
        },
        "commit_policy": {
          "type": "string"
        },
        "contract_origin": {
          "type": "string"
        },
        "path_authority": {
          "type": "string"
        },
        "acceptance_authority": {
          "type": "string"
        },
        "review_state": {
          "enum": [
            "legacy",
            "proposed",
            "approved",
            "rejected"
          ]
        },
        "review_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolution_claims": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "spawn_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "parent_task_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
