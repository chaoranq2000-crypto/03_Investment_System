  "case_id": "600673_multi_business_ma",
  "claims": [
    {
      "claim_id": "claim_600673_mix",
      "claim_type": "fact",
      "counterevidence": "分业务毛利率仍未揭示单品、客户和产线差异。",
      "evidence_ids": [
        "ev_annual_report_600673_20260410_a8e2a1"
      ],
      "locator": "page:27",
      "text": "2025年高端铝箔收入规模最大，但化工新材料毛利率显著更高，收入规模与利润贡献不能混同。"
    },
    {
      "claim_id": "claim_600673_quota",
      "claim_type": "management_comment",
      "counterevidence": "配额不等于销量，价格和成本变化也会改变利润。",
      "evidence_ids": [
        "ev_annual_report_600673_20260410_a8e2a1"
      ],
      "locator": "page:12",
      "text": "年报披露公司2026年第三代制冷剂配额约6万吨，实际销量、价格和盈利仍需后续验证。"
    },
    {
      "claim_id": "claim_600673_ma_pending",
      "claim_type": "fact",
      "counterevidence": "审批、交割、融资安排和最终并表时点均存在不确定性。",
      "evidence_ids": [
        "ev_announcement_600673_20260616_da320e"
      ],
      "locator": "page:16,25",
      "text": "交易草案列示作价80.502亿元及拟实现间接持有目标公司100%股权，但交易仍需股东会、交易所审核、注册及可能的反垄断程序。"
    },
    {
      "claim_id": "claim_600673_idc_cost",
      "claim_type": "fact",
      "counterevidence": "实际费用取决于机柜、电量、投运和结算，关联交易还需持续检查公允性。",
      "evidence_ids": [
        "ev_announcement_600673_20260625_c5ca5c"
      ],
      "locator": "page:1,3",
      "text": "IDC关联采购公告预计十二个月采购费用不超过2亿元，该金额属于成本上限而非收入。"
    },
    {
      "claim_id": "claim_600673_compute_contract",
      "claim_type": "fact",
      "counterevidence": "交付验收、融资、利用率、客户回款和采购成本均可能影响实际履行。",
      "evidence_ids": [
        "ev_announcement_600673_20260711_54be9c"
      ],
      "locator": "page:1,3",
      "text": "算力服务采购合同预计总额130亿至150亿元、期限为验收交付后60个月，最终以实际结算为准，公告明确不构成业绩承诺或盈利预测。"
    }
  ],
