{
  "$id": "r5_night03_external_decision_manifest_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "created_by": {
      "minLength": 1,
      "type": "string"
    },
    "decisions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "candidate_artifact_path": {
            "minLength": 1,
            "type": "string"
          },
          "candidate_artifact_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "decision": {
            "enum": [
              "approved",
              "rejected"
            ]
          },
          "decision_kind": {
            "enum": [
              "analysis_acceptance",
              "evidence_acceptance",
              "human_exact_hash",
              "pointer_contract_approval"
            ]
          },
          "notes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "occurrence_id": {
            "minLength": 1,
            "type": "string"
          },
          "review_packet_path": {
            "minLength": 1,
            "type": "string"
          },
          "review_packet_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "reviewed_at": {
            "format": "date-time",
            "type": "string"
          },
          "reviewer": {
            "minLength": 1,
            "type": "string"
          },
          "reviewer_authority": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "occurrence_id",
          "decision_kind",
          "decision",
          "candidate_artifact_path",
          "candidate_artifact_sha256",
          "review_packet_path",
          "review_packet_sha256",
          "reviewer",
          "reviewer_authority",
          "reviewed_at",
          "notes"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "machine_must_not_populate_reviewer_fields": {
      "const": true
    },
    "schema_version": {
      "const": "r5_night03_external_decision_manifest_v1"
    },
    "source_queue_path": {
      "const": "reports/p1_6/r5_night_shift/r5_overnight_02_20260720/next_night_queue.yaml"
    },
    "source_queue_sha256": {
      "const": "dc2d6d6bb91b7ff326d3985d96f8eb8956a43710c61230eb06e6144e490e8ea1"
    }
  },
  "required": [
    "schema_version",
    "source_queue_path",
    "source_queue_sha256",
    "created_by",
    "created_at",
    "decisions",
    "machine_must_not_populate_reviewer_fields"
  ],
  "type": "object"
}
