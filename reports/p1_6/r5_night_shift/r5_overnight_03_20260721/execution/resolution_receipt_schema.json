{
  "$id": "r5_night03_resolution_receipt_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "commands": {
      "type": "array"
    },
    "decision_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "implementation_tree_sha": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "lineage_match": {
      "type": "boolean"
    },
    "occurrence_id": {
      "minLength": 1,
      "type": "string"
    },
    "outputs": {
      "type": "array"
    },
    "resolution_claim_allowed": {
      "type": "boolean"
    },
    "source_queue_sha256": {
      "const": "dc2d6d6bb91b7ff326d3985d96f8eb8956a43710c61230eb06e6144e490e8ea1"
    },
    "stable_receipt_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "terminal_status": {
      "enum": [
        "passed",
        "failed"
      ]
    }
  },
  "publication_head_forbidden": true,
  "required": [
    "occurrence_id",
    "decision_digest_sha256",
    "source_queue_sha256",
    "implementation_tree_sha",
    "commands",
    "outputs",
    "terminal_status",
    "lineage_match",
    "resolution_claim_allowed",
    "stable_receipt_sha256"
  ],
  "type": "object"
}
