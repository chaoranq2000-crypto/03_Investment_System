# A-share Research OS environment example
# Copy to .env and fill locally. Do not commit .env.

PROJECT_NAME=a-share-research-os
PROJECT_TIMEZONE=Asia/Shanghai
DEFAULT_LANGUAGE=zh-CN

# Optional data/service credentials. Leave blank in P0.
TUSHARE_TOKEN=
TUSHARE_HTTP_URL=https://fast.xiaodefa.cn
TUSHARE_API_URL=https://fast.xiaodefa.cn
TUSHARE_DISABLE_PROXY=false
OPENAI_API_KEY=
DATABASE_URL=

# Local paths
RESEARCH_DB_PATH=data/db/research.duckdb
EVIDENCE_MANIFEST_PATH=data/manifests/evidence_manifest.csv
